{
    "name": "lekkeratlas",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "development": "vite",
        "build": "tsc -b && vite build",
        "lint": "eslint . --ext .ts,.tsx --max-warnings 0 && tsc -b --noEmit && prettier --check .",
        "lint:fix": "eslint . --ext .ts,.tsx --fix && prettier --write . && tsc -b --noEmit",
        "typecheck": "tsc --noEmit",
        "preview": "vite preview",
        "generate:api": "openapi-typescript http://localhost:8080/api-docs -o src/lib/api/schema.ts"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.100.6",
        "oidc-client-ts": "^3.5.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-oidc-context": "^3.3.1",
        "react-router": "^8.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^24.12.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "openapi-typescript": "^7.13.0",
        "prettier": "^3.9.4",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.57.0",
        "vite": "^8.0.1"
    }
}
